@misc{ouyang_stochastic_2013,
	title = {Stochastic {ADMM} for {Nonsmooth} {Optimization}},
	url = {http://arxiv.org/abs/1211.0632},
	doi = {10.48550/arXiv.1211.0632},
	abstract = {We present a stochastic setting for optimization problems with nonsmooth convex separable objective functions over linear equality constraints. To solve such problems, we propose a stochastic Alternating Direction Method of Multipliers (ADMM) algorithm. Our algorithm applies to a more general class of nonsmooth convex functions that does not necessarily have a closed-form solution by minimizing the augmented function directly. We also demonstrate the rates of convergence for our algorithm under various structural assumptions of the stochastic functions: \$O(1/{\textbackslash}sqrt\{t\})\$ for convex functions and \$O({\textbackslash}log t/t)\$ for strongly convex functions. Compared to previous literature, we establish the convergence rate of ADMM algorithm, for the first time, in terms of both the objective value and the feasibility violation.},
	publisher = {arXiv},
	author = {Ouyang, Hua and He, Niao and Gray, Alexander},
	year = {2013},
	keywords = {Computer Science - Machine Learning, Mathematics - Optimization and Control, Statistics - Machine Learning},
}

