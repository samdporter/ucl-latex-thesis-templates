	title = {Total {Variation} {Spatial} {Regularization} for {Sparse} {Hyperspectral} {Unmixing} {\textbar} {IEEE} {Journals} \& {Magazine} {\textbar} {IEEE} {Xplore}},
	url = {https://ieeexplore.ieee.org/abstract/document/6196219},
