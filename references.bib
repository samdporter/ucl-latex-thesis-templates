@article{xie_joint_2024-3,
	title = {Joint diffusion: mutual consistency-driven diffusion model for {PET}-{MRI} co-reconstruction},
	volume = {69},
	issn = {0031-9155},
	shorttitle = {Joint diffusion},
	url = {https://doi.org/10.1088/1361-6560/ad6117},
	doi = {10.1088/1361-6560/ad6117},
	abstract = {Objective. Positron Emission Tomography and Magnetic Resonance Imaging (PET-MRI) systems can obtain functional and anatomical scans. But PET suffers from a low signal-to-noise ratio, while MRI are time-consuming. To address time-consuming, an effective strategy involves reducing k-space data collection, albeit at the cost of lowering image quality. This study aims to leverage the inherent complementarity within PET-MRI data to enhance the image quality of PET-MRI. Approach. A novel PET-MRI joint reconstruction model, termed MC-Diffusion, is proposed in the Bayesian framework. The joint reconstruction problem is transformed into a joint regularization problem, where data fidelity terms of PET and MRI are expressed independently. The regular term, the derivative of the logarithm of the joint probability distribution of PET and MRI, employs a joint score-based diffusion model for learning. The diffusion model involves the forward diffusion process and the reverse diffusion process. The forward diffusion process adds noise to transform a complex joint data distribution into a known joint prior distribution for PET and MRI simultaneously, resembling a denoiser. The reverse diffusion process removes noise using a denoiser to revert the joint prior distribution to the original joint data distribution, effectively utilizing joint probability distribution to describe the correlations of PET and MRI for improved quality of joint reconstruction. Main results. Qualitative and quantitative improvements are observed with the MC-Diffusion model. Comparative analysis against LPLS and Joint ISAT-net on the ADNI dataset demonstrates superior performance by exploiting complementary information between PET and MRI. The MC-Diffusion model effectively enhances the quality of PET and MRI images. Significance. This study employs the MC-Diffusion model to enhance the quality of PET-MRI images by integrating the fundamental principles of PET and MRI modalities and leveraging their inherent complementarity. Furthermore, utilizing the diffusion model to learn the joint probability distribution of PET and MRI, thereby elucidating their latent correlation, facilitates a more profound comprehension of the priors obtained through deep learning, contrasting with black-box prior or artificially constructed structural similarities.},
	language = {en},
	number = {15},
	urldate = {2025-12-04},
	journal = {Physics in Medicine \& Biology},
	publisher = {IOP Publishing},
	author = {Xie, Taofeng and Cui, Zhuo-Xu and Luo, Chen and Wang, Huayu and Liu, Congcong and Zhang, Yuanzhi and Wang, Xuemei and Zhu, Yanjie and Chen, Guoqing and Liang, Dong and Jin, Qiyu and Zhou, Yihang and Wang, Haifeng},
	month = jul,
	year = {2024},
	pages = {155019},
}

@article{hu_unsupervised_2024,
	chapter = {Physics, Instrumentation \&amp; Data Sciences - Image Generation},
	title = {Unsupervised low-dose {PET} image reconstruction based on pre-trained denoising diffusion probabilistic prior},
	volume = {65},
	copyright = {© 2024},
	issn = {0161-5505, 2159-662X},
	url = {https://jnm.snmjournals.org/content/65/supplement_2/241109},
	abstract = {241109
Introduction: Reducing the radioactive dose is crucial for minimizing patient exposure to radiation in PET imaging. However, dose reduction often compromises image quality, potentially impairing diagnostic precision. The emergence of deep learning has introduced a variety of techniques that utilize neural networks for learning and designing image priors, significantly advancing the development of low-dose reconstruction techniques. Particularly, recent innovations in generative AI (e.g. diffusion models) have shown promise in stably addressing inverse problems using un-supervised learning. In this work, we proposed a novel denoising diffusion probabilistic model (DDPM) based low dose PET image reconstruction method, named DDPEM. The proposed DDPEM integrates the iterative process of Expectation Maximization (EM) with the reverse sampling process of DDPM. This integration leverages the predicted posterior estimates to apply the data fidelity corrections to the sampled images, which effectively harnesses the potential of pre-trained PET image priors without need of registration and supervised training.
Methods: Seventy brain subjects were scanned on a Siemens Biograph Vision Quadra with approval of the local institutional review board. The radio-tracer used in this study is 18F-FDG and the image dimensions for each subject is 128*128*40 voxels. Sixty subjects (2400 2D slices) were selected for the DDPM prior training and the remaining ten subjects (400 2D slices) were used for testing. To simulate low-dose sinograms, we generated data with low statistical counts by applying dose reduction factors of 10, 50 and 100. During the forward process in DDPEM, varying levels of Gaussian noise were added to the training image samples, creating a set of noise-corrupted images. A Unet architecture was trained to predict the level of noise added to these corrupted images. After training, this Unet effectively functions as an estimator for the score function of the distribution of the PET images. In the reverse sampling phase, Tweedie's approximation was utilized to estimate the clean image from the noise-corrupted images in each step, leveraging the well-trained Unet. Following this, a single iteration of EM was applied to each clean estimate. This EM iteration aims to correct the posterior mean of the reversely sampled images in each step. As the distance between the results of EM and subsequent clean estimates bounded, this sampling process converges towards the solution that optimizes the Poisson log-likelihood of PET measurements.
Results: Fig. 1 presents the reconstruction results from the sinograms at different dose levels, from top to bottom, the rows represent the Maximum Likelihood Expectation Maximization (MLEM), Total Variation regularized EM, and the proposed DDPEM. The proposed method displayed a robust reconstruction results across various dose levels, even in the ultra-low-dose situation. The superior performance of our method is clearly demonstrated in Figure 1. The quantitative results are shown in Table. 1. Our method better demonstrates PSNR and SSIM at all dose levels except the SSIM of EMTV at 100x dose reduction. It is because the SSIM index is computed in a way that is biased on smoother image like the one reconstructed by EM-TV.
Conclusions: In this work, we proposed DDPEM, the first unsupervised low dose PET image reconstruction model using DDPM in EM algorithm. The reconstruction results from different dose levels' sinogram by DDPEM can achieve better results than MLEM and EM-TV both visually and quantitatively. Particularly in ultra-low dose reconstructions, our method demonstrates exceptional robustness, showing great promise for clinical applications.{\textless}img class="highwire-fragment fragment-image" alt="Figure" src="https://jnm.snmjournals.org/content/jnumed/65/supplement\_2/241109/F1.medium.gif" width="434" height="440"/{\textgreater}Download figureOpen in new tabDownload powerpoint},
	language = {en},
	number = {supplement 2},
	urldate = {2025-12-04},
	journal = {Journal of Nuclear Medicine},
	publisher = {Society of Nuclear Medicine},
	author = {Hu, Rui and Wu, Dufan and Tivnan, Matthew and Guo, Ning and Yoon, Siyeop and Chen, Zhennong and Wang, Yuang and Luo, Jie and Xue, Song and Cui, Jianan and Liu, Huafeng and Li, Quanzheng},
	month = jun,
	year = {2024},
	pages = {241109--241109},
}

@article{mehranian_model-based_2021,
	title = {Model-{Based} {Deep} {Learning} {PET} {Image} {Reconstruction} {Using} {Forward}–{Backward} {Splitting} {Expectation}–{Maximization}},
	volume = {5},
	issn = {2469-7303},
	url = {https://ieeexplore.ieee.org/document/9123435},
	doi = {10.1109/TRPMS.2020.3004408},
	abstract = {We propose a forward-backward splitting algorithm to integrate deep learning into maximum-a-posteriori (MAP) positron emission tomography (PET) image reconstruction. The MAP reconstruction is split into regularization, expectation-maximization (EM), and a weighted fusion. For regularization, the use of either a Bowsher prior (using Markov-random fields) or a residual learning unit (using convolutional-neural networks) were considered. For the latter, our proposed forward-backward splitting EM (FBSEM), accelerated with ordered subsets (OS), was unrolled into a recurrent-neural network in which network parameters (including regularization strength) are shared across all states and learned during PET reconstruction. Our network was trained and evaluated using PET-only (FBSEM-p) and PET-MR (FBSEM-pm) datasets for low-dose simulations and short-duration in-vivo brain imaging. It was compared to OSEM, Bowsher MAPEM, and a post-reconstruction U-Net denoising trained on the same PET-only (Unet-p) or PET-MR (Unet-pm) datasets. For simulations, FBSEM-p(m) and Unet-p(m) nets achieved a comparable performance, on average, 14.4\% and 13.4\% normalized root-mean square error (NRMSE), respectively; and both outperformed OSEM and MAPEM methods (with 20.7\% and 17.7\% NRMSE, respectively). For in-vivo datasets, FBSEM-p(m), Unet-p(m), MAPEM, and OSEM methods achieved average root-sum-of-squared errors of 3.9\%, 5.7\%, 5.9\%, and 7.8\% in different brain regions, respectively. In conclusion, the studied U-Net denoising method achieved a comparable performance to a representative implementation of the FBSEM net.},
	number = {1},
	urldate = {2025-12-04},
	journal = {IEEE Transactions on Radiation and Plasma Medical Sciences},
	author = {Mehranian, Abolfazl and Reader, Andrew J.},
	month = jan,
	year = {2021},
	keywords = {Brain modeling, Deep learning, Deep learning (DL), Image reconstruction, MRI, Noise reduction, Optimization, Positron emission tomography, Training, image reconstruction, positron emission tomography (PET)},
	pages = {54--64},
}

@article{mehranian_model-based_2020,
	title = {Model-{Based} {Deep} {Learning} {PET} {Image} {Reconstruction} {Using} {Forward}-{Backward} {Splitting} {Expectation}-{Maximization}},
	volume = {5},
	issn = {2469-7311},
	doi = {10.1109/TRPMS.2020.3004408},
	abstract = {We propose a forward-backward splitting algorithm to integrate deep learning into maximum-a-posteriori (MAP) positron emission tomography (PET) image reconstruction. The MAP reconstruction is split into regularization, expectation-maximization (EM), and a weighted fusion. For regularization, the use of either a Bowsher prior (using Markov-random fields) or a residual learning unit (using convolutional-neural networks) were considered. For the latter, our proposed forward-backward splitting EM (FBSEM), accelerated with ordered subsets (OS), was unrolled into a recurrent-neural network in which network parameters (including regularization strength) are shared across all states and learned during PET reconstruction. Our network was trained and evaluated using PET-only (FBSEM-p) and PET-MR (FBSEM-pm) datasets for low-dose simulations and short-duration in-vivo brain imaging. It was compared to OSEM, Bowsher MAPEM, and a post-reconstruction U-Net denoising trained on the same PET-only (Unet-p) or PET-MR (Unet-pm) datasets. For simulations, FBSEM-p(m) and Unet-p(m) nets achieved a comparable performance, on average, 14.4\% and 13.4\% normalized root-mean square error (NRMSE), respectively; and both outperformed OSEM and MAPEM methods (with 20.7\% and 17.7\% NRMSE, respectively). For in-vivo datasets, FBSEM-p(m), Unet-p(m), MAPEM, and OSEM methods achieved average root-sum-of-squared errors of 3.9\%, 5.7\%, 5.9\%, and 7.8\% in different brain regions, respectively. In conclusion, the studied U-Net denoising method achieved a comparable performance to a representative implementation of the FBSEM net.},
