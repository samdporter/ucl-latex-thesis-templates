	doi = {10.1016/J.APRADISO.2006.08.009},
	abstract = {90Y is utilized as a therapeutic radioisotope in radiolabeled monoclonal antibodies and in microspheres for targeted radiation therapy of the liver. Currently, the widely used dose calibrator assay of 90Y can have uncertainties exceeding ±10\%. A non-destructive assay using spectroscopy is possible by reducing the currently published uncertainty (±12\%) in the internal pair production branching ratio for the 0+-0+ transition of 90Zr. A high-purity germanium detector was used to determine the branching ratio to be (31.86±0.47)×10-6. © 2006 Elsevier Ltd. All rights reserved.},
