	doi = {10.1053/j.semnuclmed.2021.12.009},
	abstract = {Radiomicrosphere Therapy (RMT) refers to a liver-directed therapeutic modality based on the intrahepatic arterial administration of radiolabeled microspheres. There is a need for standardization of the terminology of RMT. A descriptive identifier should first name the radioisotope, then the chemical formulation of the microsphere, and lastly add the term RMT that indicates the therapeutic modality. At present, clinically available options include {\textbar}Y-90{\textbar} {\textbar}Resin{\textbar} {\textbar}RMT{\textbar}, {\textbar}Y-90{\textbar} {\textbar}Glass{\textbar} {\textbar}RMT{\textbar} and {\textbar}Ho-166{\textbar} {\textbar}PLLA{\textbar} {\textbar}RMT{\textbar}. The latter is available in Europe and is being considered for clearance by the FDA in the United States. Preclinical studies with {\textbar}Re-188{\textbar} {\textbar}PLLA{\textbar} {\textbar}RMT{\textbar} are underway. Dosimetric considerations are strongly tied to both the type of the radioisotope and the chemical composition of the microsphere type. This review will focus on Y-90 resin and glass RMT, the history, dosimetry, clinical use, and controversies.},
	number = {2},
	urldate = {2025-02-21},
	journal = {Seminars in Nuclear Medicine},
	author = {Gulec, Seza A. and McGoron, Anthony J.},
	month = mar,
	year = {2022},
	pages = {215--228},
}

@article{knoll_joint_2017,
	title = {Joint {MR}-{PET} {Reconstruction} {Using} a {Multi}-{Channel} {Image} {Regularizer}},
	volume = {36},
	issn = {1558-254X},
	url = {https://ieeexplore.ieee.org/abstract/document/7466848},
	doi = {10.1109/TMI.2016.2564989},
	abstract = {While current state of the art MR-PET scanners enable simultaneous MR and PET measurements, the acquired data sets are still usually reconstructed separately. We propose a new multi-modality reconstruction framework using second order Total Generalized Variation (TGV) as a dedicated multi-channel regularization functional that jointly reconstructs images from both modalities. In this way, information about the underlying anatomy is shared during the image reconstruction process while unique differences are preserved. Results from numerical simulations and in-vivo experiments using a range of accelerated MR acquisitions and different MR image contrasts demonstrate improved PET image quality, resolution, and quantitative accuracy.},
	number = {1},
	urldate = {2024-12-16},
	journal = {IEEE Transactions on Medical Imaging},
	author = {Knoll, Florian and Holler, Martin and Koesters, Thomas and Otazo, Ricardo and Bredies, Kristian and Sodickson, Daniel K},
	month = jan,
	year = {2017},
	note = {Conference Name: IEEE Transactions on Medical Imaging},
	keywords = {Couplings, Image edge detection, Image reconstruction, Iterative image reconstruction, MR-PET, Positron emission tomography, TV, Tensile stress, multi-modality imaging, total generalized variation, variational regularization methods},
	pages = {1--16},
}

