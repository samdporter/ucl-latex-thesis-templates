@inproceedings{deidda_feasibility_2021,
	title = {Feasibility of {Image} {Reconstruction} from {Triple} {Modality} {Data} of {Yttrium}-90},
	url = {/home/sam/Zotero/storage/XPDNW773/9875695.html},
	doi = {10.1109/NSS/MIC44867.2021.9875695},
	abstract = {The recent implementation of the first clinical triple modality scanner in STIR enables investigation of the possibility of triple modality image reconstruction. Such a tool represents an important step toward the improvement of dosimetry for theranostics, where the exploitation of multi-modality imaging can have an impact on treatment planning and follow-up. To give a demonstration of triple modality image reconstruction we used data from a NEMA phantom that was filled with Yttrium-90 (90Y), which emits Bremsstrahlung photons detectable with SPECT as well as gamma rays that can go through pair production, therefore creating positrons that make PET acquisition possible. The data were acquired with the Mediso AnyScan SPECT/PET/CT. Different ways of including multiple side information using the kernelised expectation maximisation (KEM) and the Hybrid KEM (HKEM) were used and investigated in terms of ROI activity and noise suppression. This work presents an example of application with 90Y but it can be extended to any other radionuclide combination used in Theranostic applications.},
	booktitle = {2021 {IEEE} {Nuclear} {Science} {Symposium} and {Medical} {Imaging} {Conference} ({NSS}/{MIC})},
	author = {Deidda, Daniel and Denis-Bacelar, Ana and Fenwick, Andrew and Ferreira, Kelley and Heetun, Warda and Hutton, Brian F and Scuffham, James and Robinson, Andrew P and Thielemans, Kris},
	year = {2021},
	keywords = {Dosimetry, Imaging phantoms, Planning, Positron emission tomography, Positrons, Production, Single photon emission computed tomography},
	pages = {1--3},
}

