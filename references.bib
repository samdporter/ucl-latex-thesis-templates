@misc{noauthor_validation_nodate,
	title = {Validation of {SPECT}-{CT} image reconstruction for the {Mediso} {AnyScan} {SCP} scanner in {STIR} {\textbar} {IEEE} {Conference} {Publication} {\textbar} {IEEE} {Xplore}},
