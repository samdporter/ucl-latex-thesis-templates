	keywords = {Biomedical imaging, Computed tomography, Convergence, Electrical capacitance tomography, Image reconstruction, Isotopes, Maximum likelihood detection, Maximum likelihood estimation, Penalised, Positron emission tomography, Single photon emission computed tomography},
	pages = {132--137},
}

