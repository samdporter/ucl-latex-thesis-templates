@article{gear_eanm_2023,
	title = {{EANM} enabling guide: how to improve the accessibility of clinical dosimetry},
	volume = {50},
	issn = {1619-7089},
	shorttitle = {{EANM} enabling guide},
	url = {https://doi.org/10.1007/s00259-023-06226-z},
	doi = {10.1007/s00259-023-06226-z},
	abstract = {Dosimetry can be a useful tool for personalization of molecular radiotherapy (MRT) procedures, enabling the continuous development of theranostic concepts. However, the additional resource requirements are often seen as a barrier to implementation. This guide discusses the requirements for dosimetry and demonstrates how a dosimetry regimen can be tailored to the available facilities of a centre. The aim is to help centres wishing to initiate a dosimetry service but may not have the experience or resources of some of the more established therapy and dosimetry centres. The multidisciplinary approach and different personnel requirements are discussed and key equipment reviewed example protocols demonstrating these factors are given in the supplementary material for the main therapies carried out in nuclear medicine, including [131I]-NaI for benign thyroid disorders, [177Lu]-DOTATATE and 131I-mIBG for neuroendocrine tumours and [90Y]-microspheres for unresectable hepatic carcinoma.},
	language = {en},
	number = {7},
	urldate = {2026-02-01},
	journal = {European Journal of Nuclear Medicine and Molecular Imaging},
	author = {Gear, Jonathan and Stokke, Caroline and Terwinghe, Christelle and Gnesin, Silvano and Sandström, Mattias and Tran-Gia, Johannes and Cremonesi, Marta and Cicone, Francesco and Verburg, Fredrik and Hustinx, Roland and Giovanella, Luca and Herrmann, Ken and Gabiña, Pablo Minguez},
	month = jun,
