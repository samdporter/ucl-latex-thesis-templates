	publisher = {Royal College of Physicians},
	author = {Sundram, Francis X. and Buscombe, John R.},
	month = oct,
	year = {2017},
	keywords = {Internal, Liver, Malignancy, Radiation, SIRT, Selective, Therapy},
	pages = {449},
}

