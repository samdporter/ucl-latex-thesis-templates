@inproceedings{ryu_performance_2017,
	title = {Performance {Evaluation} of {Quantitative} {SPECT}/{CT}: {Applying} {NEMA} {NU2} {PET} {Measurements} to {SPECT}},
	issn = {2577-0829},
	shorttitle = {Performance {Evaluation} of {Quantitative} {SPECT}/{CT}},
	url = {https://ieeexplore.ieee.org/document/8532647},
	doi = {10.1109/NSSMIC.2017.8532647},
	abstract = {SPECT and PET systems were tested using the methodology defined in NEMA NU 2-2012 Performance Measurements of Positron Emission Tomographs.{\textasciicircum}99mTc and {\textasciicircum}177Luwere used to test on the SPECT (Symbia- Intevo, Siemens Healthcare) and 1S{\textbackslash}Gamma was used for the PET (Biograph-mCT, Siemens Healthcare). The spatial resolution was measured in radial and tangential directions. Scatter fraction and count losses were measured with a line source inserted into a cylinder phantom. The sensitivity was measured using a uniform line source surrounded by aluminum sleeves ofvarying thickness. Five aluminum sleeves with different diameters were used to measure the attenuated count rate with accumulated wall thicknesses to extrapolate to “zero attenuation”The spatial resolution for radial/tangential directions at 1 cm were: 5.29/4.30 mm, 12.6/14.1 mm and 21.6 {\textbackslash}mathrm m{\textbackslash}mathrm m/23.4 mm for 1S{\textbackslash}Gamma, 99{\textbackslash}mathrm m{\textbackslash}mathrm T{\textbackslash}mathrm c and 177{\textbackslash}mathrm L{\textbackslash}mathrm u, respectively. The event rates of {\textasciicircum}99mTc showed linear increase with activity. The sensitivities at 0/10{\textbackslash}mathrm c{\textbackslash}mathrm m off axis were: 9.63{\textbackslash}times 10{\textasciicircum}3/9.59{\textbackslash}times 10{\textasciicircum}3 cps/MBq, 119.4/116.7 cps/MBq, and 47.6/47.5 cps/MBq for 1S{\textbackslash}Gamma, 99{\textbackslash}mathrm m{\textbackslash}mathrm T{\textbackslash}mathrm c and 177{\textbackslash}mathrm L{\textbackslash}mathrm u, respectively. The scatter fractions of 1S{\textbackslash}Gamma, 99{\textbackslash}mathrm m{\textbackslash}mathrm T{\textbackslash}mathrm c and {\textasciicircum}177Luwere 0.32, 0.25 and 0.36. The background variability was 1.52\%, 2.73\% and 6.51\% for 1S{\textbackslash}Gamma, 99{\textbackslash}mathrm m{\textbackslash}mathrm T{\textbackslash}mathrm c and 177{\textbackslash}mathrm L{\textbackslash}mathrm u, respectively. The hot sphere contrast was 69.8\%, 78.5\% and 64.7\% for 1S{\textbackslash}Gamma, 99{\textbackslash}mathrm m{\textbackslash}mathrm T{\textbackslash}mathrm c and 177{\textbackslash}mathrm L{\textbackslash}mathrm u, respectively. True concentration ratio of {\textasciicircum}99mTc and {\textasciicircum}177Luon SPECT were 7.2:1 and 5.8:1, where {\textbackslash}mathrm S{\textbackslash}mathrm U{\textbackslash}mathrm V\_{\textbackslash}max in hot spheres and background SUVs were 6.9/0.98 and 5.5/10.4 for {\textasciicircum}99mTc and 177{\textbackslash}mathrm L{\textbackslash}mathrm u, respectively, on the quantitative SPECT images.This study underscores the transition of SPECT from a qualitative or semi-quantitative imaging modality to a fully quantitative clinical tool.},
	urldate = {2024-12-11},
	booktitle = {2017 {IEEE} {Nuclear} {Science} {Symposium} and {Medical} {Imaging} {Conference} ({NSS}/{MIC})},
	author = {Ryu, HyunJu and Eslick, Enid and Willowson, Kathy P and Meikle, Steven R and Bailey, Dale L},
	month = oct,
	year = {2017},
	keywords = {Australia, Loss measurement, Positron emission tomography, Sensitivity, Single photon emission computed tomography, Spatial resolution},
	pages = {1--2},
}

@article{rault_fast_2010,
	title = {Fast simulation of yttrium-90 bremsstrahlung photons with {GATE}},
	volume = {37},
	issn = {2473-4209},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1118/1.3431998},
	doi = {10.1118/1.3431998},
	abstract = {Purpose Multiple investigators have recently reported the use of yttrium-90 bremsstrahlung single photon emission computed tomography (SPECT) imaging for the dosimetry of targeted radionuclide therapies. Because Monte Carlo (MC) simulations are useful for studying SPECT imaging, this study investigates the MC simulation of bremsstrahlung photons in SPECT. To overcome the computationally expensive simulation of electrons, the authors propose a fast way to simulate the emission of bremsstrahlung photons based on prerecorded bremsstrahlung photon probability density functions (PDFs). Methods The accuracy of bremsstrahlung photon simulation is evaluated in two steps. First, the validity of the fast bremsstrahlung photon generator is checked. To that end, fast and analog simulations of photons emitted from a point source in a water phantom are compared. The same setup is then used to verify the accuracy of the bremsstrahlung photon simulations, comparing the results obtained with PDFs generated from both simulated and measured data to measurements. In both cases, the energy spectra and point spread functions of the photons detected in a scintillation camera are used. Results Results show that the fast simulation method is responsible for a 5\% overestimation of the low-energy fluence (below 75 keV) of the bremsstrahlung photons detected using a scintillation camera. The spatial distribution of the detected photons is, however, accurately reproduced with the fast method and a computational acceleration of -fold is achieved. When measured PDFs are used in the simulations, the simulated energy spectrum of photons emitted from a point source of in a water phantom and detected in a scintillation camera closely approximates the measured spectrum. The PSF of the photons imaged in the 50–300 keV energy window is also accurately estimated with a 12.4\% underestimation of the full width at half maximum and 4.5\% underestimation of the full width at tenth maximum. Conclusions Despite its limited accuracy, the fast bremsstrahlung photon generator is well suited for the simulation of bremsstrahlung photons emitted in large homogeneous organs, such as the liver, and detected in a scintillation camera. The computational acceleration makes it very useful for future investigations of bremsstrahlung SPECT imaging.},
	language = {en},
	number = {6Part1},
	urldate = {2024-12-11},
	journal = {Medical Physics},
	author = {Rault, Erwann and Staelens, Steven and Van Holen, Roel and De Beenhouwer, Jan and Vandenberghe, Stefaan},
	year = {2010},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1118/1.3431998},
	keywords = {Anatomy, Applications, Cameras, Dosimetry, Emission spectra, Medical image reconstruction, Medical imaging, Monte Carlo methods, Photons, Probability density functions, SPECT, Single photon emission computed tomography, Single photon emission computed tomography (SPECT), bremsstrahlung, cameras, dosimetry, phantoms, radiation therapy, simulation, single photon emission computed tomography},
	pages = {2943--2950},
}

