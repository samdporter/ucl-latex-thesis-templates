@article{pan_deep_2024,
	title = {Deep learned triple-tracer multiplexed {PET} myocardial image separation},
	volume = {4},
	issn = {2673-8880},
	url = {https://www.frontiersin.org/journals/nuclear-medicine/articles/10.3389/fnume.2024.1379647/full},
	doi = {10.3389/fnume.2024.1379647},
	abstract = {{\textless}sec{\textgreater}{\textless}title{\textgreater}Introduction{\textless}/title{\textgreater}{\textless}p{\textgreater}In multiplexed positron emission tomography (mPET) imaging, physiological and pathological information from different radiotracers can be observed simultaneously in a single dynamic PET scan. The separation of mPET signals within a single PET scan is challenging due to the fact that the PET scanner measures the sum of the PET signals of all the tracers. The conventional multi-tracer compartment modeling (MTCM) method requires staggered injections and assumes that the arterial input functions (AIFs) of each tracer are known.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}{\textless}sec{\textgreater}{\textless}title{\textgreater}Methods{\textless}/title{\textgreater}{\textless}p{\textgreater}In this work, we propose a deep learning-based method to separate triple-tracer PET images without explicitly knowing the AIFs. A dynamic triple-tracer noisy MLEM reconstruction was used as the network input, and dynamic single-tracer noisy MLEM reconstructions were used as training labels.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}{\textless}sec{\textgreater}{\textless}title{\textgreater}Results{\textless}/title{\textgreater}{\textless}p{\textgreater}A simulation study was performed to evaluate the performance of the proposed framework on triple-tracer ([{\textless}inline-formula{\textgreater}{\textless}mml:math xmlns:mml="http://www.w3.org/1998/Math/MathML" id="IM1"{\textgreater}{\textless}mml:msup{\textgreater}{\textless}mml:mi{\textgreater} {\textless}/mml:mi{\textgreater}{\textless}mml:mrow{\textgreater}{\textless}mml:mn{\textgreater}18{\textless}/mml:mn{\textgreater}{\textless}/mml:mrow{\textgreater}{\textless}/mml:msup{\textgreater}{\textless}/mml:math{\textgreater}{\textless}/inline-formula{\textgreater}F]FDG+{\textless}inline-formula{\textgreater}{\textless}mml:math xmlns:mml="http://www.w3.org/1998/Math/MathML" id="IM2"{\textgreater}{\textless}mml:msup{\textgreater}{\textless}mml:mi{\textgreater} {\textless}/mml:mi{\textgreater}{\textless}mml:mrow{\textgreater}{\textless}mml:mn{\textgreater}82{\textless}/mml:mn{\textgreater}{\textless}/mml:mrow{\textgreater}{\textless}/mml:msup{\textgreater}{\textless}/mml:math{\textgreater}{\textless}/inline-formula{\textgreater}Rb+[{\textless}inline-formula{\textgreater}{\textless}mml:math xmlns:mml="http://www.w3.org/1998/Math/MathML" id="IM3"{\textgreater}{\textless}mml:msup{\textgreater}{\textless}mml:mi{\textgreater} {\textless}/mml:mi{\textgreater}{\textless}mml:mrow{\textgreater}{\textless}mml:mn{\textgreater}94{\textless}/mml:mn{\textgreater}{\textless}mml:mrow{\textgreater}{\textless}mml:mi mathvariant="normal"{\textgreater}m{\textless}/mml:mi{\textgreater}{\textless}/mml:mrow{\textgreater}{\textless}/mml:mrow{\textgreater}{\textless}/mml:msup{\textgreater}{\textless}/mml:math{\textgreater}{\textless}/inline-formula{\textgreater}Tc]sestamibi) PET myocardial imaging. The results show that the proposed methodology substantially reduced the noise level compared to the results obtained from single-tracer imaging. Additionally, it achieved lower bias and standard deviation in the separated single-tracer images compared to the MTCM-based method at both the voxel and region of interest (ROI) levels.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}{\textless}sec{\textgreater}{\textless}title{\textgreater}Discussion{\textless}/title{\textgreater}{\textless}p{\textgreater}As compared to MTCM separation, the proposed method uses spatiotemporal information for separation, which improves the separation performance at both the voxel and ROI levels. The simulation study also demonstrates the feasibility and potential of the proposed DL-based method for the application to pre-clinical and clinical studies.{\textless}/p{\textgreater}{\textless}/sec{\textgreater}},
	language = {English},
	urldate = {2024-09-19},
	journal = {Frontiers in Nuclear Medicine},
	publisher = {Frontiers},
	author = {Pan, Bolin and Marsden, Paul K. and Reader, Andrew J.},
	month = apr,
	year = {2024},
	keywords = {Data - Driven Learning, Image separation, Multiplexed positron emission tomography, compartmental modeling, deep learning},
}

